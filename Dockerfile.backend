# GusEngine V10 — Backend Dockerfile
# Self-contained: downloads tokenizer during build, includes Qdrant restore
FROM python:3.11-slim

WORKDIR /app

# System dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download Qwen tokenizer to a known local directory (for token counting)
RUN python -c "from transformers import AutoTokenizer; t = AutoTokenizer.from_pretrained('Qwen/Qwen2.5-32B-Instruct-AWQ', trust_remote_code=True); t.save_pretrained('/models/tokenizer')"

# Application code
COPY backend/ backend/
COPY frontend/ frontend/
COPY config/ config/

# Qdrant backup for first-boot restore
COPY storage/backups/ storage/backups/

# PDFs for deep reference
COPY storage/pdfs/ storage/pdfs/

# Entrypoint script that restores Qdrant backup if needed, then starts the server
COPY docker-entrypoint.sh .
RUN chmod +x docker-entrypoint.sh

EXPOSE 8888

ENTRYPOINT ["./docker-entrypoint.sh"]

# GusEngine V10 — Backend Dockerfile
# Self-contained: downloads tokenizer during build
FROM python:3.11-slim

WORKDIR /app

# System dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download Qwen tokenizer to a known local directory (for token counting)
RUN python -c "from transformers import AutoTokenizer; t = AutoTokenizer.from_pretrained('Qwen/Qwen2.5-32B-Instruct-AWQ', trust_remote_code=True); t.save_pretrained('/models/tokenizer')"

# Application code
COPY backend/ backend/
COPY frontend/ frontend/
COPY config/ config/

# Entrypoint script
COPY docker-entrypoint.sh .
RUN chmod +x docker-entrypoint.sh

EXPOSE 8888

ENTRYPOINT ["./docker-entrypoint.sh"]
